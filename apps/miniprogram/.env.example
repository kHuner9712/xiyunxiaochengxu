# 微信小程序 AppID（仅用于构建时注入 manifest.json）
# 注意：VITE_WX_APPID 不是 AppSecret，不具备支付/登录密钥能力
# 体验版/正式版构建必须在本地或 CI Secret 中提供真实 AppID
# 严禁提交 .env.production、真实 AppID、真实 AppSecret 到仓库
# 开发环境可保留占位值 wx0000000000000000
# 体验版/正式版构建命令：
# NODE_ENV=production VITE_WX_APPID=真实AppID pnpm build:mini
# 或 pnpm build:mini:prod（需提前在本地环境变量/CI Secret 配置 VITE_WX_APPID）
VITE_WX_APPID=wx0000000000000000

# API 基础路径（微信小程序必须配置完整 HTTPS 域名）
# 开发环境示例：http://localhost:3000/api
# 生产环境示例：https://your-domain.com/api
VITE_API_BASE_URL=https://api.yunxixiaochengxu.com.cn/api
# 生产环境必须使用 HTTPS
