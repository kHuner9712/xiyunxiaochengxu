# 微信小程序 AppID（构建时注入 manifest.json）
# 必须在体验版/正式版构建前填写到本地 .env，不得提交真实 AppID/Secret
# 开发环境可保留占位值 wx0000000000000000
# 体验版/正式版构建命令：NODE_ENV=production VITE_WX_APPID=真实AppID pnpm build:mini
VITE_WX_APPID=wx0000000000000000

# API 基础路径（微信小程序必须配置完整 HTTPS 域名）
# 开发环境示例：http://localhost:3000/api
# 生产环境示例：https://your-domain.com/api
VITE_API_BASE_URL=https://api.yunxixiaochengxu.com.cn/api
# 生产环境必须使用 HTTPS
