generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending_payment
  paid
  pending_delivery
  pending_pickup
  delivered
  completed
  cancelled
  aftersale
}

enum AftersaleStatus {
  pending_review
  approved
  rejected
  returned
  pending_refund
  refunded
  closed
}

model User {
  id              BigInt        @id @default(autoincrement()) @map("id")
  openid          String        @db.VarChar(64) @map("openid")
  unionId         String?       @db.VarChar(64) @map("union_id")
  phone           String?       @db.VarChar(20) @map("phone")
  nickname        String?       @db.VarChar(50) @map("nickname")
  avatarUrl       String?       @db.VarChar(500) @map("avatar_url")
  gender          Int           @default(0) @map("gender")
  memberLevelId   BigInt?       @map("member_level_id")
  memberLevel     MemberLevel?  @relation(fields: [memberLevelId], references: [id])
  growthValue     Int           @default(0) @map("growth_value")
  totalPoints     Int           @default(0) @map("total_points")
  availablePoints Int           @default(0) @map("available_points")
  lastLoginAt     DateTime?     @map("last_login_at")
  status          Int           @default(1) @map("status")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  profile          UserProfile?
  addresses        UserAddress[]
  babyProfiles     BabyProfile[]
  memberRecords    UserMemberRecord[]
  pointsRecords    PointsRecord[]
  carts            Cart[]
  orders           Order[]
  userCoupons      UserCoupon[]
  shareRecords     ShareRecord[]
  invitedShares    ShareRecord[]          @relation("ShareInviter")
  inviteRecords    UserInviteRelation[]   @relation("InviterRelations")
  invitedByRecords UserInviteRelation[]   @relation("InviteeRelations")
  aftersaleOrders  AftersaleOrder[]

  @@unique([openid], name: "idx_openid")
  @@index([phone], name: "idx_phone")
  @@index([memberLevelId], name: "idx_member_level_id")
  @@map("users")
}

model UserProfile {
  id         BigInt    @id @default(autoincrement()) @map("id")
  userId     BigInt    @unique @map("user_id")
  realName   String?   @db.VarChar(50) @map("real_name")
  birthday   DateTime? @db.Date @map("birthday")
  babyCount  Int       @default(0) @map("baby_count")
  source     String?   @db.VarChar(20) @map("source")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@map("user_profiles")
}

model UserAddress {
  id            BigInt    @id @default(autoincrement()) @map("id")
  userId        BigInt    @map("user_id")
  receiverName  String    @db.VarChar(50) @map("receiver_name")
  receiverPhone String    @db.VarChar(20) @map("receiver_phone")
  province      String    @db.VarChar(20) @map("province")
  city          String    @db.VarChar(20) @map("city")
  district      String    @db.VarChar(20) @map("district")
  detailAddress String    @db.VarChar(200) @map("detail_address")
  isDefault     Int       @default(0) @map("is_default")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@map("user_addresses")
}

model BabyProfile {
  id               BigInt    @id @default(autoincrement()) @map("id")
  userId           BigInt    @map("user_id")
  nickname         String?   @db.VarChar(50) @map("nickname")
  gender           Int       @default(0) @map("gender")
  birthday         DateTime  @db.Date @map("birthday")
  currentMonthAge  Int?      @map("current_month_age")
  avatarUrl        String?   @db.VarChar(500) @map("avatar_url")
  isDefault        Int       @default(0) @map("is_default")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@index([birthday], name: "idx_birthday")
  @@map("baby_profiles")
}

model MemberLevel {
  id            BigInt    @id @default(autoincrement()) @map("id")
  name          String    @db.VarChar(20) @map("name")
  icon          String?   @db.VarChar(500) @map("icon")
  minGrowthValue Int      @map("min_growth_value")
  maxGrowthValue Int?     @map("max_growth_value")
  discountRate  Int?      @map("discount_rate")
  pointsRate    Int       @default(10) @map("points_rate")
  benefits      String?   @db.Text @map("benefits")
  sortOrder     Int       @default(0) @map("sort_order")
  status        Int       @default(1) @map("status")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  users           User[]
  userMemberRecords UserMemberRecord[]

  @@map("member_levels")
}

model UserMemberRecord {
  id           BigInt    @id @default(autoincrement()) @map("id")
  userId       BigInt    @map("user_id")
  oldLevelId   BigInt?   @map("old_level_id")
  newLevelId   BigInt    @map("new_level_id")
  changeReason String?   @db.VarChar(200) @map("change_reason")
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  newLevel   MemberLevel @relation(fields: [newLevelId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@map("user_member_records")
}

model PointsRecord {
  id          BigInt    @id @default(autoincrement()) @map("id")
  userId      BigInt    @map("user_id")
  type        Int       @map("type")
  points      Int       @map("points")
  balance     Int?      @map("balance")
  source      String    @db.VarChar(30) @map("source")
  sourceId    BigInt?   @map("source_id")
  description String?   @db.VarChar(200) @map("description")
  expireAt    DateTime? @map("expire_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@index([type], name: "idx_type")
  @@index([source], name: "idx_source")
  @@index([expireAt], name: "idx_expire_at")
  @@unique([source, sourceId], name: "idx_points_records_source_source_id")
  @@map("points_records")
}

model Supplier {
  id                   BigInt    @id @default(autoincrement()) @map("id")
  name                 String    @db.VarChar(100) @map("name")
  contactName          String?   @db.VarChar(50) @map("contact_name")
  contactPhone         String?   @db.VarChar(20) @map("contact_phone")
  address              String?   @db.VarChar(300) @map("address")
  businessLicense      String?   @db.VarChar(500) @map("business_license")
  cooperationStartDate DateTime? @db.Date @map("cooperation_start_date")
  settlementType       Int?      @map("settlement_type")
  remark               String?   @db.Text @map("remark")
  status               Int       @default(1) @map("status")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  products Product[]

  @@index([name], name: "idx_name")
  @@index([status], name: "idx_status")
  @@map("suppliers")
}

model Brand {
  id         BigInt    @id @default(autoincrement()) @map("id")
  name       String    @db.VarChar(50) @map("name")
  logo       String?   @db.VarChar(500) @map("logo")
  description String?  @db.Text @map("description")
  sortOrder  Int       @default(0) @map("sort_order")
  status     Int       @default(1) @map("status")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  products Product[]

  @@index([name], name: "idx_name")
  @@map("brands")
}

model ProductCategory {
  id        BigInt             @id @default(autoincrement()) @map("id")
  parentId  BigInt             @default(0) @map("parent_id")
  name      String             @db.VarChar(50) @map("name")
  icon      String?            @db.VarChar(500) @map("icon")
  complianceConfig Json?       @map("compliance_config")
  sortOrder Int                @default(0) @map("sort_order")
  isShow    Int                @default(1) @map("is_show")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  products           Product[]
  productAttributes  ProductAttribute[]

  @@index([parentId], name: "idx_parent_id")
  @@index([sortOrder], name: "idx_sort_order")
  @@map("product_categories")
}

model Product {
  id              BigInt    @id @default(autoincrement()) @map("id")
  name            String    @db.VarChar(200) @map("name")
  categoryId      BigInt    @map("category_id")
  productType     String    @default("physical") @db.VarChar(20) @map("product_type")
  fulfillmentType String    @default("delivery") @db.VarChar(20) @map("fulfillment_type")
  businessCategory String   @default("other") @db.VarChar(50) @map("business_category")
  brandId         BigInt?   @map("brand_id")
  supplierId      BigInt?   @map("supplier_id")
  mainImage       String?   @db.VarChar(500) @map("main_image")
  videoUrl        String?   @db.VarChar(500) @map("video_url")
  images          Json?     @map("images")
  description     String?   @db.Text @map("description")
  attributes      Json?     @map("attributes")
  servicePromise  Json?     @map("service_promise")
  minPrice        Int?      @map("min_price")
  maxPrice        Int?      @map("max_price")
  totalSales      Int       @default(0) @map("total_sales")
  virtualSales    Int       @default(0) @map("virtual_sales")
  status          Int       @default(3) @map("status")
  sortOrder       Int       @default(0) @map("sort_order")
  isRecommend     Int       @default(0) @map("is_recommend")
  recommendAgeMin Int?      @map("recommend_age_min")
  recommendAgeMax Int?      @map("recommend_age_max")
  isPeriodPurchase Int      @default(0) @map("is_period_purchase")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category     ProductCategory  @relation(fields: [categoryId], references: [id])
  brand        Brand?           @relation(fields: [brandId], references: [id])
  supplier     Supplier?        @relation(fields: [supplierId], references: [id])
  skus         ProductSku[]
  productImages ProductImage[]
  stockLogs    ProductStockLog[]
  activityProducts ActivityProduct[]
  orderItems   OrderItem[]
  carts        Cart[]

  @@index([categoryId], name: "idx_category_id")
  @@index([productType], name: "idx_product_type")
  @@index([fulfillmentType], name: "idx_product_fulfillment_type")
  @@index([businessCategory], name: "idx_business_category")
  @@index([brandId], name: "idx_brand_id")
  @@index([supplierId], name: "idx_supplier_id")
  @@index([status], name: "idx_status")
  @@index([sortOrder], name: "idx_sort_order")
  @@map("products")
}

model ProductSku {
  id             BigInt    @id @default(autoincrement()) @map("id")
  productId      BigInt    @map("product_id")
  skuCode        String?   @db.VarChar(50) @map("sku_code")
  specs          Json?     @map("specs")
  price          Int       @map("price")
  originalPrice  Int?      @map("original_price")
  costPrice      Int?      @map("cost_price")
  stock          Int       @default(0) @map("stock")
  sales          Int       @default(0) @map("sales")
  image          String?   @db.VarChar(500) @map("image")
  weight         Int?      @map("weight")
  barcode        String?   @db.VarChar(50) @map("barcode")
  status         Int       @default(1) @map("status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  product   Product           @relation(fields: [productId], references: [id])
  stockLogs ProductStockLog[]
  carts     Cart[]
  orderItems OrderItem[]
  activityProducts ActivityProduct[]

  @@unique([skuCode], name: "idx_sku_code")
  @@index([productId], name: "idx_product_id")
  @@index([status], name: "idx_status")
  @@map("product_skus")
}

model ProductImage {
  id        BigInt   @id @default(autoincrement()) @map("id")
  productId BigInt   @map("product_id")
  imageUrl  String   @db.VarChar(500) @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId], name: "idx_product_id")
  @@map("product_images")
}

model ProductAttribute {
  id         BigInt   @id @default(autoincrement()) @map("id")
  categoryId BigInt?  @map("category_id")
  name       String   @db.VarChar(50) @map("name")
  type       Int?     @map("type")
  values     Json?    @map("values")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId], name: "idx_category_id")
  @@map("product_attributes")
}

model ProductStockLog {
  id          BigInt    @id @default(autoincrement()) @map("id")
  productId   BigInt    @map("product_id")
  skuId       BigInt    @map("sku_id")
  type        Int       @map("type")
  quantity    Int       @map("quantity")
  beforeStock Int?      @map("before_stock")
  afterStock  Int?      @map("after_stock")
  reason      String?   @db.VarChar(200) @map("reason")
  operatorId  BigInt?   @map("operator_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  product Product    @relation(fields: [productId], references: [id])
  sku     ProductSku @relation(fields: [skuId], references: [id])

  @@index([productId], name: "idx_product_id")
  @@index([skuId], name: "idx_sku_id")
  @@index([type], name: "idx_type")
  @@index([createdAt], name: "idx_created_at")
  @@map("product_stock_logs")
}

model Cart {
  id         BigInt   @id @default(autoincrement()) @map("id")
  userId     BigInt   @map("user_id")
  productId  BigInt   @map("product_id")
  skuId      BigInt   @map("sku_id")
  quantity   Int      @default(1) @map("quantity")
  isSelected Int      @default(1) @map("is_selected")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id])
  product Product    @relation(fields: [productId], references: [id])
  sku     ProductSku @relation(fields: [skuId], references: [id])

  @@index([userId], name: "idx_user_id")
  @@unique([userId, skuId], name: "uk_user_sku")
  @@map("carts")
}

model PickupStore {
  id              BigInt    @id @default(autoincrement()) @map("id")
  name            String    @db.VarChar(100) @map("name")
  contactPhone    String?   @db.VarChar(20) @map("contact_phone")
  province        String    @db.VarChar(20) @map("province")
  city            String    @db.VarChar(20) @map("city")
  district        String    @db.VarChar(20) @map("district")
  address         String    @db.VarChar(200) @map("address")
  latitude        Decimal?  @db.Decimal(10, 7) @map("latitude")
  longitude       Decimal?  @db.Decimal(10, 7) @map("longitude")
  businessHours   String?   @db.VarChar(100) @map("business_hours")
  pickupNotice    String?   @db.VarChar(500) @map("pickup_notice")
  status          Int       @default(1) @map("status")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  orders Order[]

  @@index([status], name: "idx_pickup_store_status")
  @@map("pickup_stores")
}

model Order {
  id                   BigInt      @id @default(autoincrement()) @map("id")
  orderNo              String      @db.VarChar(32) @map("order_no")
  userId               BigInt      @map("user_id")
  status               OrderStatus @default(pending_payment) @map("status")
  totalAmount          Int         @map("total_amount")
  discountAmount       Int         @default(0) @map("discount_amount")
  freightAmount        Int         @default(0) @map("freight_amount")
  pointsAmount         Int         @default(0) @map("points_amount")
  payAmount            Int?        @map("pay_amount")
  pointsDeducted       Int         @default(0) @map("points_deducted")
  couponId             BigInt?     @map("coupon_id")
  couponAmount         Int         @default(0) @map("coupon_amount")
  activityDiscountAmount Int       @default(0) @map("activity_discount_amount")
  receiverName         String      @db.VarChar(50) @map("receiver_name")
  receiverPhone        String      @db.VarChar(20) @map("receiver_phone")
  province             String?     @db.VarChar(20) @map("province")
  city                 String?     @db.VarChar(20) @map("city")
  district             String?     @db.VarChar(20) @map("district")
  detailAddress        String?     @db.VarChar(200) @map("detail_address")
  remark               String?     @db.VarChar(200) @map("remark")
  adminRemark          String?     @db.VarChar(200) @map("admin_remark")
  paidAt               DateTime?   @map("paid_at")
  deliveredAt          DateTime?   @map("delivered_at")
  completedAt          DateTime?   @map("completed_at")
  cancelledAt          DateTime?   @map("cancelled_at")
  cancelReason         String?     @db.VarChar(200) @map("cancel_reason")
  autoCloseAt          DateTime?   @map("auto_close_at")
  autoCompleteAt       DateTime?   @map("auto_complete_at")
  source               String?     @default("miniprogram") @db.VarChar(20) @map("source")
  sourceType           String      @default("direct") @db.VarChar(30) @map("source_type")
  sourceCode           String?     @db.VarChar(64) @map("source_code")
  shareRecordId        BigInt?     @map("share_record_id")
  shareCampaignId      BigInt?     @map("share_campaign_id")
  referrerUserId       BigInt?     @map("referrer_user_id")
  fulfillmentType      String      @default("delivery") @db.VarChar(20) @map("fulfillment_type")
  pickupStoreId        BigInt?     @map("pickup_store_id")
  pickupStoreName      String?     @db.VarChar(100) @map("pickup_store_name")
  pickupStoreAddress   String?     @db.VarChar(300) @map("pickup_store_address")
  pickupContactPhone   String?     @db.VarChar(20) @map("pickup_contact_phone")
  pickupCode           String?     @db.VarChar(8) @map("pickup_code")
  pickedUpAt           DateTime?   @map("picked_up_at")
  pickupVerifiedBy     BigInt?     @map("pickup_verified_by")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id])
  pickupStore    PickupStore?   @relation(fields: [pickupStoreId], references: [id])
  orderItems     OrderItem[]
  payment        OrderPayment?
  delivery       OrderDelivery?
  orderLogs      OrderLog[]
  aftersaleOrders AftersaleOrder[]
  orderRefunds   OrderRefund[]

  @@unique([orderNo], name: "uk_order_no")
  @@index([userId], name: "idx_user_id")
  @@index([status], name: "idx_status")
  @@index([createdAt], name: "idx_created_at")
  @@index([paidAt], name: "idx_paid_at")
  @@index([sourceType], name: "idx_order_source_type")
  @@index([sourceCode], name: "idx_order_source_code")
  @@index([shareRecordId], name: "idx_order_share_record_id")
  @@index([shareCampaignId], name: "idx_order_share_campaign_id")
  @@index([referrerUserId], name: "idx_order_referrer_user_id")
  @@index([fulfillmentType], name: "idx_fulfillment_type")
  @@unique([pickupCode], name: "uk_pickup_code")
  @@map("orders")
}

model OrderItem {
  id              BigInt    @id @default(autoincrement()) @map("id")
  orderId         BigInt    @map("order_id")
  productId       BigInt    @map("product_id")
  skuId           BigInt    @map("sku_id")
  productName     String    @db.VarChar(200) @map("product_name")
  skuSpecs        Json?     @map("sku_specs")
  productImage    String?   @db.VarChar(500) @map("product_image")
  price           Int       @map("price")
  originalPrice   Int?      @map("original_price")
  quantity        Int       @map("quantity")
  subtotal        Int       @map("subtotal")
  activityId      BigInt?   @map("activity_id")
  activityType    String?   @db.VarChar(20) @map("activity_type")
  activityDiscount Int      @default(0) @map("activity_discount")
  supplierId      BigInt?   @map("supplier_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  order     Order          @relation(fields: [orderId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  sku       ProductSku     @relation(fields: [skuId], references: [id])

  aftersaleOrders AftersaleOrder[]

  @@index([orderId], name: "idx_order_id")
  @@index([productId], name: "idx_product_id")
  @@index([supplierId], name: "idx_supplier_id")
  @@map("order_items")
}

model OrderPayment {
  id             BigInt   @id @default(autoincrement()) @map("id")
  orderId        BigInt   @unique @map("order_id")
  paymentNo      String?  @db.VarChar(64) @map("payment_no")
  transactionId  String?  @db.VarChar(64) @map("transaction_id")
  amount         Int      @map("amount")
  paymentMethod  String?  @default("wechat") @db.VarChar(20) @map("payment_method")
  status         Int      @default(1) @map("status")
  paidAt         DateTime? @map("paid_at")
  rawResponse    Json?    @map("raw_response")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@unique([paymentNo], name: "uk_payment_no")
  @@unique([transactionId], name: "idx_transaction_id")
  @@index([orderId], name: "idx_order_id")
  @@map("order_payments")
}

model OrderDelivery {
  id                BigInt   @id @default(autoincrement()) @map("id")
  orderId           BigInt   @unique @map("order_id")
  logisticsCompany  String?  @db.VarChar(50) @map("logistics_company")
  logisticsNo       String?  @db.VarChar(50) @map("logistics_no")
  deliveryImages    Json?    @map("delivery_images")
  deliveredAt       DateTime? @map("delivered_at")
  receivedAt        DateTime? @map("received_at")
  logisticsInfo     Json?    @map("logistics_info")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId], name: "idx_order_id")
  @@index([logisticsNo], name: "idx_logistics_no")
  @@map("order_delivery")
}

model OrderLog {
  id           BigInt   @id @default(autoincrement()) @map("id")
  orderId      BigInt   @map("order_id")
  operatorType String?  @db.VarChar(10) @map("operator_type")
  operatorId   BigInt?  @map("operator_id")
  action       String   @db.VarChar(30) @map("action")
  content      String?  @db.Text @map("content")
  createdAt    DateTime @default(now()) @map("created_at")

