# ===========================================
# 母婴商城 Docker 环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ===========================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=shopxo_dev_123
MYSQL_DATABASE=shopxo
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_general_ci

# MySQL 端口映射（留空则不暴露到宿主机）
MYSQL_HOST_PORT=

# Redis 端口映射（留空则不暴露到宿主机）
REDIS_HOST_PORT=

# Nginx 端口映射
NGINX_HOST_PORT=8080

# uni-app 开发环境 API 地址
UNI_APP_REQUEST_URL=http://localhost:8080/
