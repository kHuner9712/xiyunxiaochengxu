# ============================================
# 禧孕母婴用品私域商城小程序 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# ---------- 应用配置 ----------
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ---------- 数据库配置 ----------
DATABASE_URL=mysql://root:your_db_password@localhost:3306/baby_mall
DB_HOST=localhost
DB_PORT=3306
DB_NAME=baby_mall
DB_USER=root
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4

# ---------- Redis 配置 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ---------- JWT 配置 ----------
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=2h

# ---------- 微信小程序配置 ----------
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_app_secret

# ---------- 微信支付 V3 配置 ----------
WECHAT_MCH_ID=your_mch_id
WECHAT_MCH_SERIAL_NO=your_cert_serial_no
WECHAT_API_V3_KEY=your_api_v3_key
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_NOTIFY_URL=https://your-domain.com/api/weapp/pay/callback

# ---------- 文件上传配置 ----------
UPLOAD_DRIVER=local
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4

# ---------- 腾讯云 COS 配置（预留） ----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou

# ---------- 阿里云 OSS 配置（预留） ----------
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-guangzhou
OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com

# ---------- 订单配置 ----------
ORDER_AUTO_CLOSE_MINUTES=30
ORDER_AUTO_COMPLETE_DAYS=15
ORDER_AUTO_COMPLETE_REMIND_DAYS=12

# ---------- 积分配置 ----------
POINTS_RATE_PER_YUAN=1
POINTS_SIGN_IN_BASE=5
POINTS_SIGN_IN_MAX=15
POINTS_SHARE_AWARD=2
POINTS_SHARE_DAILY_LIMIT=10
POINTS_PROFILE_AWARD=10
POINTS_REVIEW_AWARD=5
POINTS_REVIEW_DAILY_LIMIT=20
POINTS_REGISTER_AWARD=50
POINTS_DEDUCT_RATE=100
POINTS_DEDUCT_MAX_PERCENT=30
POINTS_EXPIRE_MONTHS=12

# ---------- 会员等级配置 ----------
MEMBER_LEVEL_NORMAL_MAX=999
MEMBER_LEVEL_SILVER_MIN=1000
MEMBER_LEVEL_SILVER_MAX=4999
MEMBER_LEVEL_GOLD_MIN=5000
MEMBER_LEVEL_GOLD_MAX=19999
MEMBER_LEVEL_BLACK_GOLD_MIN=20000

# ---------- 运费配置 ----------
FREIGHT_FREE_AMOUNT=99
FREIGHT_DEFAULT_FEE=10
FREIGHT_REMOTE_AREAS=新疆,西藏,内蒙古,青海,甘肃
FREIGHT_REMOTE_FEE=20

# ---------- 日志配置 ----------
LOG_LEVEL=info
LOG_DIR=./logs

# ---------- 跨域配置 ----------
CORS_ORIGINS=https://your-admin-domain.com

# ---------- 管理后台配置 ----------
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_this_password
