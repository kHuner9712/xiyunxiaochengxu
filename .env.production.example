# ============================================
# 禧孕优选 生产环境模板（可提交）
# 复制为 .env.production 后填写真实值
# 严禁提交 .env.production
# ============================================

# ---------- 基础 ----------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ---------- 数据库 ----------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=baby_mall
DB_USER=root
DB_PASSWORD="REPLACE_WITH_STRONG_DB_PASSWORD"
DATABASE_URL=mysql://root:REPLACE_WITH_STRONG_DB_PASSWORD@mysql:3306/baby_mall
# 说明：
# 1) Docker Compose 部署时，API 容器通常会基于 DB_PASSWORD/DB_NAME 组装 DATABASE_URL。
# 2) 如在宿主机手工运行 API（非容器），请同步填写可直连的 DATABASE_URL。

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD="REPLACE_WITH_STRONG_REDIS_PASSWORD"

# ---------- 鉴权 ----------
JWT_SECRET="REPLACE_WITH_STRONG_JWT_SECRET"
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=2h
REFRESH_TOKEN_SECRET="REPLACE_WITH_STRONG_REFRESH_TOKEN_SECRET"
REFRESH_TOKEN_EXPIRES_IN=30d

# ---------- 微信小程序 ----------
WECHAT_APP_ID=REPLACE_WITH_REAL_WX_APP_ID
WECHAT_APP_SECRET=REPLACE_WITH_REAL_WX_APP_SECRET

# ---------- 微信支付 V3 ----------
WECHAT_MCH_ID=REPLACE_WITH_REAL_MCH_ID
WECHAT_MCH_SERIAL_NO=REPLACE_WITH_REAL_MCH_SERIAL_NO
WECHAT_API_V3_KEY=REPLACE_WITH_REAL_API_V3_KEY
WECHAT_PRIVATE_KEY_PATH=/app/apps/api/certs/apiclient_key.pem
WECHAT_PLATFORM_CERT_PATH=/app/apps/api/certs/wechatpay_platform.pem
WECHAT_PLATFORM_CERT_SERIAL_NO=REPLACE_WITH_REAL_PLATFORM_CERT_SERIAL_NO
WECHAT_NOTIFY_URL=https://api.yunxixiaochengxu.com.cn/api/weapp/pay/callback
WECHAT_REFUND_NOTIFY_URL=https://api.yunxixiaochengxu.com.cn/api/weapp/pay/refund-callback
WECHAT_SKIP_VERIFY=false

# ---------- 管理后台 ----------
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD="REPLACE_WITH_STRONG_ADMIN_PASSWORD"
SMOKE_TEST_BYPASS_CAPTCHA=false

# ---------- 跨域 ----------
CORS_ORIGINS=https://admin.yunxixiaochengxu.com.cn

# ---------- 上传 ----------
UPLOAD_DIR=/app/apps/api/uploads
# 上传文件大小限制，单位 bytes（默认 10MB = 10485760）
UPLOAD_MAX_SIZE=10485760
# 允许上传的 MIME 类型，逗号分隔（默认 image/jpeg,image/png,image/gif,image/webp,video/mp4）
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4
UPLOAD_PUBLIC_URL=https://api.yunxixiaochengxu.com.cn
# 公开文件路径为 /uploads/public/...；私有文件仅允许通过后端鉴权接口访问

# ---------- 业务参数 ----------
ORDER_AUTO_CLOSE_MINUTES=30
ORDER_AUTO_COMPLETE_DAYS=15
FREIGHT_FREE_AMOUNT=99
FREIGHT_DEFAULT_FEE=10
FREIGHT_REMOTE_FEE=20
POINTS_DEDUCT_RATE=100
POINTS_DEDUCT_MAX_PERCENT=30

# ---------- SSL 证书路径（Nginx） ----------
SSL_FULLCHAIN_PATH=deploy/nginx/ssl/fullchain.pem
SSL_PRIVKEY_PATH=deploy/nginx/ssl/privkey.pem

# ---------- 说明 ----------
# 1. WECHAT_PRIVATE_KEY_PATH / WECHAT_PLATFORM_CERT_PATH 为 API 容器内读取路径。
# 2. 证书文件需由运维放置到宿主机以下路径（通过 docker volume 映射到容器内）：
#    - deploy/certs/apiclient_key.pem
#    - deploy/certs/wechatpay_platform.pem
#    - deploy/nginx/ssl/fullchain.pem
#    - deploy/nginx/ssl/privkey.pem
# 3. 密码/密钥建议至少16位，包含大小写字母、数字和特殊字符。
# 4. 如值包含空格、#、$、& 等特殊字符，建议使用双引号包裹。
