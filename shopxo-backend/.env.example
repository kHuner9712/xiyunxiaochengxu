# 非 Docker 环境配置（宝塔 / 独立服务器 / WAMP / MAMP）
# 用法：复制为 .env 并修改为实际数据库信息
# Docker 环境请使用 .env.docker.example

APP_DEBUG = true

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = shopxo_dev
USERNAME = root
PASSWORD = CHANGE_ME_STRONG_PASSWORD
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX = sxo_

[LANG]
default_lang = zh-cn
