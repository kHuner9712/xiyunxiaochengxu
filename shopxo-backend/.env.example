# ============================================================
# ShopXO 后端环境配置模板
# 使用方式：复制本文件为 .env，根据环境修改配置
# 警告：.env 文件绝不可提交到 Git
# ============================================================

[APP]
DEBUG = false

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = shopxo
USERNAME = shopxo
PASSWORD = 请替换为强密码
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX = sxo_

# ============================================================
# 宝塔部署专用说明
# ============================================================
# 1. HOSTNAME: 宝塔环境下使用 127.0.0.1（本机 MySQL）
# 2. DATABASE: 建议使用 shopxo 或自定义数据库名
# 3. USERNAME: 建议创建专用数据库用户，不要用 root
# 4. PASSWORD: 必须使用强密码（8位以上，含大小写字母+数字+特殊字符）
# 5. HOSTPORT: 宝塔默认 MySQL 端口 3306
# 6. CHARSET: 必须使用 utf8mb4（支持 emoji 和中文）
# 7. PREFIX: 保持 sxo_ 不变
