# ============================================================
# 禧孕小程序 — 后端生产环境配置示例
# ============================================================
#
# 【用法】
#   1. 复制本文件: cp .env.production.example .env
#   2. 替换所有占位符为实际值
#   3. 确认 APP_DEBUG = false
#   4. 确认密码与 MySQL 实际密码一致
#
# 【占位符说明】
#   {{DB_HOST}}   → 数据库主机地址（非 Docker 环境填 IP，如 10.0.1.50）
#   {{DB_NAME}}   → 数据库名，如 xiyun_prod
#   {{DB_USER}}   → 数据库用户名，如 xiyun_app（不要使用 root）
#   {{DB_PASS}}   → 数据库密码（强密码，≥16位，含大小写+数字+特殊字符）
#
# ⚠️ 本文件包含占位符，不可直接使用！必须替换后再部署。
# ⚠️ 不要将真实密码提交到 Git！
# ⚠️ 生产环境 APP_DEBUG 必须为 false！
#
# 【宝塔部署注意事项】
#   - PHP 版本：8.1（不要使用 7.x 或 8.2+，未经兼容测试）
#   - MySQL 版本：5.7（不要使用 8.0，SQL 迁移脚本基于 5.7 测试）
#   - 网站运行目录：设为 /public（不是根目录！）
#   - 伪静态：选择 thinkphp 或手动添加 rewrite 规则
#   - SSL：必须开启 HTTPS，申请 Let's Encrypt 或上传证书
#   - 禁止公网访问 .env 文件（Nginx 规则已配置）
#   - 禁止公网访问 runtime/log 目录
#   - phpMyAdmin 不建议公网开放（如需使用，限制 IP 白名单）
#   - MySQL 3306 端口不开放公网（仅允许本机 127.0.0.1 连接）
#   - 禁用 PHP 危险函数：exec, shell_exec, system, passthru, popen
#   - 上传文件大小限制：≥ 20MB（php.ini post_max_size / upload_max_filesize）
# ============================================================

APP_DEBUG = false

[DATABASE]
TYPE = mysql
HOSTNAME = {{DB_HOST}}
DATABASE = {{DB_NAME}}
USERNAME = {{DB_USER}}
PASSWORD = {{DB_PASS}}
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX = sxo_

[LANG]
default_lang = zh-cn

# ============================================================
# 母婴二开配置
# ============================================================

# 资质门禁模式（phase_one=一期宽松模式 / phase_two=二期严格模式）
# 一期请保持 phase_one
MUYING_QUALIFICATION_MODE = phase_one

# 隐私加密密钥（AES-256-CBC）
# 生成方式: php -r "echo bin2hex(openssl_random_pseudo_bytes(32));"
# ⚠️ 不要提交真实密钥到 Git！
# ⚠️ 生产环境必须配置，否则用户敏感数据无法加密！
# ⚠️ 密钥长度必须 >= 16 字符！
MUYING_PRIVACY_KEY = {{PRIVACY_KEY}}
