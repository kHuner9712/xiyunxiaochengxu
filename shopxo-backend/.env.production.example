# ============================================================
# 孕禧小程序 — 后端生产环境配置示例
# ============================================================
#
# 【用法】
#   1. 复制本文件: cp .env.production.example .env
#   2. 替换所有占位符为实际值
#   3. 确认 APP_DEBUG = false
#   4. 确认密码与 MySQL 实际密码一致
#
# 【占位符说明】
#   {{DB_HOST}}   → 数据库主机地址（非 Docker 环境填 IP，如 10.0.1.50）
#   {{DB_NAME}}   → 数据库名，如 yunxi_prod
#   {{DB_USER}}   → 数据库用户名，如 yunxi_app
#   {{DB_PASS}}   → 数据库密码（强密码）
#
# ⚠️ 本文件包含占位符，不可直接使用！必须替换后再部署。
# ⚠️ 不要将真实密码提交到 Git！
# ============================================================

APP_DEBUG = false

[DATABASE]
TYPE = mysql
HOSTNAME = {{DB_HOST}}
DATABASE = {{DB_NAME}}
USERNAME = {{DB_USER}}
PASSWORD = {{DB_PASS}}
HOSTPORT = 3306
CHARSET = utf8mb4
PREFIX = sxo_

[LANG]
default_lang = zh-cn
