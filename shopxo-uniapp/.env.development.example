# ============================================================
# 本地开发环境配置模板
# 使用方式：复制本文件为 .env.development，修改为你的本地地址
# ============================================================

# 环境标识
UNI_APP_ENV=local

# 后端 API 地址（必填，末尾保留 /）
# Docker 环境：http://localhost:8080/
# 直连后端：http://127.0.0.1:8080/
# 局域网调试：http://你的局域网IP:8080/
UNI_APP_REQUEST_URL=http://localhost:8080/
VUE_APP_UNI_APP_REQUEST_URL=http://localhost:8080/

# 静态资源地址（可选，默认与 REQUEST_URL 相同）
UNI_APP_STATIC_URL=http://localhost:8080/
VUE_APP_UNI_APP_STATIC_URL=http://localhost:8080/

# 上传地址（可选，默认与 REQUEST_URL 相同）
# UNI_APP_UPLOAD_URL=http://localhost:8080/

# 微信小程序 AppID（本地开发可用测试号）
UNI_APP_WX_APPID=wxda7779770f53e901
VUE_APP_UNI_APP_WX_APPID=wxda7779770f53e901
