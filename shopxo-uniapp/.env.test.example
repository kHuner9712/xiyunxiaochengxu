# ============================================================
# 测试环境配置模板
# 使用方式：复制本文件为 .env.test，修改为测试服务器地址
# 场景：测试号 + 测试服务器联调
# ============================================================

# 环境标识
UNI_APP_ENV=test

# 后端 API 地址（必填，末尾保留 /）
UNI_APP_REQUEST_URL=http://测试服务器IP:8080/
VUE_APP_UNI_APP_REQUEST_URL=http://测试服务器IP:8080/

# 静态资源地址
UNI_APP_STATIC_URL=http://测试服务器IP:8080/
VUE_APP_UNI_APP_STATIC_URL=http://测试服务器IP:8080/

# 微信小程序 AppID（测试号）
UNI_APP_WX_APPID=wxda7779770f53e901
VUE_APP_UNI_APP_WX_APPID=wxda7779770f53e901
