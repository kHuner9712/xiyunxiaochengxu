# ============================================================
# 预发布/验收环境配置模板
# 使用方式：复制本文件为 .env.staging，修改为预发布服务器地址
# 场景：正式 AppID + 预发布服务器 + HTTPS
# ============================================================

# 环境标识
UNI_APP_ENV=staging

# 后端 API 地址（必填，HTTPS，末尾保留 /）
UNI_APP_REQUEST_URL=https://staging.你的域名.com/
VUE_APP_UNI_APP_REQUEST_URL=https://staging.你的域名.com/

# 静态资源地址
UNI_APP_STATIC_URL=https://staging.你的域名.com/
VUE_APP_UNI_APP_STATIC_URL=https://staging.你的域名.com/

# 微信小程序 AppID（正式 AppID）
UNI_APP_WX_APPID=你的正式AppID
VUE_APP_UNI_APP_WX_APPID=你的正式AppID
