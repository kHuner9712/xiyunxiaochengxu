# ============================================================
# 孕禧小程序 — 前端发布构建环境变量示例
# ============================================================
#
# 【用法】
#   本文件不是 uni-app 自动读取的配置文件，而是发布前的变量参考。
#   在 HBuilderX 发行时，需要手动设置以下环境变量。
#
# 【HBuilderX 设置方式】
#   1. 打开 HBuilderX
#   2. 菜单：运行 → 运行到小程序模拟器 → 运行时是否压缩代码（发行时选是）
#   3. 菜单：发行 → 小程序-微信
#   4. 在发行弹窗中设置环境变量：
#      UNI_APP_REQUEST_URL = https://你的API域名/
#      UNI_APP_STATIC_URL  = https://你的CDN域名/  （可选）
#
# 【占位符说明】
#   {{API_DOMAIN}} → 后端 API 域名，如 api.yunxi.com
#   {{CDN_DOMAIN}} → CDN 域名（可与 API 同域），如 cdn.yunxi.com
#
# ⚠️ 本文件包含占位符，不可直接使用！
# ============================================================

# --- 必须设置 ---

# 后端 API 接口地址（必须以 https:// 开头，以 / 结尾）
UNI_APP_REQUEST_URL=https://{{API_DOMAIN}}/

# --- 可选设置 ---

# 静态资源 CDN 地址（留空则使用 API 域名）
UNI_APP_STATIC_URL=https://{{CDN_DOMAIN}}/

# --- 构建验证 ---
# 构建完成后，在产物中搜索域名确认替换成功：
#   grep -r "api.yunxi" unpackage/dist/build/mp-weixin/
#   grep -r "UNI_APP_REQUEST_URL" unpackage/dist/build/mp-weixin/
