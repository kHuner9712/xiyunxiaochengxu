# ============================================================
# 正式生产环境配置模板
# 使用方式：复制本文件为 .env.production，填入正式配置
# 警告：此文件包含生产密钥，绝不可提交到 Git
# ============================================================

# 环境标识
UNI_APP_ENV=production

# 后端 API 地址（必填，HTTPS，末尾保留 /）
UNI_APP_REQUEST_URL=https://你的域名.com/
VUE_APP_UNI_APP_REQUEST_URL=https://你的域名.com/

# 静态资源地址（默认与 API 地址相同，CDN 部署时单独配置）
UNI_APP_STATIC_URL=https://你的域名.com/
VUE_APP_UNI_APP_STATIC_URL=https://你的域名.com/

# 上传地址（默认与 API 地址相同，OSS 部署时单独配置）
# UNI_APP_UPLOAD_URL=https://你的域名.com/

# 微信小程序 AppID（必填，正式 AppID）
UNI_APP_WX_APPID=你的正式AppID
VUE_APP_UNI_APP_WX_APPID=你的正式AppID
